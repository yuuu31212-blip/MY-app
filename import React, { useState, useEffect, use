// MARK: - 自作高解像度SVGレーダーチャート (ライブラリ一切不要)
// ────────────────────────────────────────────────────────
interface ChartProps {
  evalData: { [key: string]: number };
  fields: EvalField[];
  isPrint: boolean;
}

function SVGChart({ evalData, fields, isPrint }: ChartProps) {
  const size = 150;
  const center = size / 2;
  const radius = center * 0.75;
  const numAxes = fields.length;

  if (numAxes < 3) return <div className="text-4xs text-slate-400">チャート表示不可</div>;

  // 各軸の角度を計算
  const angleSlice = (Math.PI * 2) / numAxes;

  // 同心円グリッド
  const grids = [1, 2, 3, 4, 5];

  // データ頂点の座標計算
  const points = fields.map((field, i) => {
    const score = evalData[field.id] ?? 3;
    const r = radius * (score / 5);
    const angle = angleSlice * i - Math.PI / 2; // 上から開始
    const x = center + r * Math.cos(angle);
    const y = center + r * Math.sin(angle);
    return { x, y };
  });

  const polygonPointsStr = points.map(p => `${p.x},${p.y}`).join(' ');

  // 軸線の描画
  const axisLines = fields.map((field, i) => {
    const angle = angleSlice * i - Math.PI / 2;
    const x = center + radius * Math.cos(angle);
    const y = center + radius * Math.sin(angle);

    // テキスト表示座標
    const textDist = radius + 14;
    const tx = center + textDist * Math.cos(angle);
    const ty = center + textDist * Math.sin(angle) + 3; // 微調整

    return {
      x2: x,
      y2: y,
      tx,
      ty,
      name: field.name.substring(0, 4)
    };
  });

  // 印刷時と画面時のグリッド線の色の調整
  const strokeColor = isPrint ? 'rgba(0,0,0,0.18)' : 'rgba(100,116,139,0.2)';
  const polygonColor = 'rgba(16,185,129,0.15)';
  const strokePolygonColor = '#10b981';

  return (
    <svg width="100%" height="100%" viewBox={`0 0 ${size} ${size}`}>
      {/* 同心円 */}
      {grids.map(g => (
        <circle
          key={g}
          cx={center}
          cy={center}
          r={radius * (g / 5)}
          fill="none"
          stroke={strokeColor}
          strokeWidth="0.8"
        />
      ))}

      {/* 放射軸線 */}
      {axisLines.map((axis, i) => (
        <g key={i}>
          <line
            x1={center}
            y1={center}
            x2={axis.x2}
            y2={axis.y2}
            stroke={strokeColor}
            strokeWidth="0.8"
          />
          <text
            x={axis.tx}
            y={axis.ty}
            textAnchor="middle"
            fontSize="7"
            fontWeight="bold"
            fill={isPrint ? "#000" : "#64748b"}
          >
            {axis.name}
          </text>
        </g>
      ))}

      {/* 評価多角形プロット */}
      <polygon
        points={polygonPointsStr}
        fill={polygonColor}
        stroke={strokePolygonColor}
        strokeWidth="1.8"
      />
    </svg>
  );
}

