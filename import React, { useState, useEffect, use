  const [phone, setPhone] = useState('');
  const [address, setAddress] = useState('');
  const [interviewDate, setInterviewDate] = useState('');
  
  const [selectedWeekdays, setSelectedWeekdays] = useState<string[]>([]);
  const [weeklyDays, setWeeklyDays] = useState<string>('未設定 (タップで選択)');
  const [hoursWeekday, setHoursWeekday] = useState('');
  const [hoursWeekend, setHoursWeekend] = useState('');
  const [commute, setCommute] = useState('徒歩');
  const [period, setPeriod] = useState('長期可能 (1年以上)');
  
  const [evalScores, setEvalScores] = useState<{ [key: string]: number }>({});
  const [selectedTags, setSelectedTags] = useState<string[]>([]);
  const [status, setStatus] = useState('検討中');
  const [notes, setNotes] = useState('');

  // 1タップセレクト用
  const [showingDaysPicker, setShowingDaysPicker] = useState(false);
  const daysOptions = [
    "週1日", "週1〜2日", "週2日", "週2〜3日", "週3日",
    "週3〜4日", "週4日", "週4〜5日", "週5日以上",
    "土日のみ", "平日のみ", "不定期・要相談"
  ];

  // 初期値セット
  useEffect(() => {
    if (candidate) {
      setName(candidate.name);
      setAge(String(candidate.age));
      setJob(candidate.job);
      setPhone(candidate.phone);
      setAddress(candidate.address);
      setInterviewDate(candidate.interviewDate);
      setSelectedWeekdays(candidate.weekdays);
      setWeeklyDays(candidate.weeklyDays);
      setHoursWeekday(candidate.hoursWeekday);
      setHoursWeekend(candidate.hoursWeekend);
      setCommute(candidate.commute);
      setPeriod(candidate.period);
      setEvalScores(candidate.eval);
      setSelectedTags(candidate.tags);
      setStatus(candidate.status);
      setNotes(candidate.notes);
    } else {
      // 登録時の初期設定値
      setInterviewDate(new Date().toISOString().split('T')[0]);
      const initialScores: { [key: string]: number } = {};
      evalFields.forEach(f => {
        initialScores[f.id] = 3;
      });
      setEvalScores(initialScores);
    }
  }, [candidate, evalFields]);

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    if (!name.trim()) return;

    const data: Candidate = {
      id: candidate?.id || `candidate-${Date.now()}`,
      name: name.trim(),
      age: Number(age) || 18,
      job: job.trim() || 'フリーター',
      phone: phone.trim(),
      address: address.trim(),
      weekdays: selectedWeekdays,
      weeklyDays: weeklyDays === '未設定 (タップで選択)' ? '週3〜4日' : weeklyDays,
      hoursWeekday,
      hoursWeekend,
      commute,
      period,
      eval: evalScores,
      tags: selectedTags,
      status,
      notes,
      createdAt: candidate?.createdAt || Date.now()
    };
    onSave(data);
  };

  const handleWeekdayToggle = (day: string) => {
    if (selectedWeekdays.includes(day)) {
      setSelectedWeekdays(selectedWeekdays.filter(d => d !== day));
    } else {
      setSelectedWeekdays([...selectedWeekdays, day]);
    }
  };

  const handleTagToggle = (tag: string) => {
    if (selectedTags.includes(tag)) {
      setSelectedTags(selectedTags.filter(t => t !== tag));
    } else {
      setSelectedTags([...selectedTags, tag]);
    }
  };

  return (
    <div className="fixed inset-0 bg-black/60 backdrop-blur-xs z-40 flex items-center justify-center p-3 sm:p-5 overflow-y-auto">
      <div className="bg-white rounded-xl border border-slate-200 shadow-2xl w-full max-w-2xl max-h-[92vh] flex flex-col overflow-hidden animate-in fade-in zoom-in duration-150">
        
        {/* ヘッダー */}
        <div className="px-5 py-3.5 bg-slate-50 border-b border-slate-200 flex justify-between items-center shrink-0">
          <h3 className="text-sm font-extrabold text-slate-800 flex items-center gap-1.5">
            <UserPlus className="w-4.5 h-4.5 text-emerald-500" />
            <span>{candidate ? "面接候補者データの編集" : "新規面接候補者 登録"}</span>
          </h3>
          <button 
            onClick={onClose}
            className="w-7 h-7 rounded-full bg-slate-100 hover:bg-slate-200 text-slate-500 flex items-center justify-center transition"
          >
            <X className="w-4 h-4" />
          </button>
        </div>

        {/* フォーム中身 */}
        <form onSubmit={handleSubmit} className="flex-1 overflow-y-auto p-5 space-y-4 text-xs">
          
          {/* セクション1: 基本情報 */}
          <div className="space-y-2.5 border-b border-slate-100 pb-3.5">
            <h4 className="text-4xs font-black text-emerald-600 uppercase tracking-widest flex items-center gap-1">
              <span className="w-1 h-2.5 bg-emerald-500 rounded-full" />
              1. 候補者の基本情報
            </h4>
            
            <div className="grid grid-cols-1 sm:grid-cols-3 gap-3">
              <div>
                <label className="block text-4xs text-slate-400 mb-1 font-bold">氏名 <span className="text-rose-500">*</span></label>
                <input 
                  type="text" 
                  required 
                  placeholder="例：鈴木 実" 
                  value={name}
                  onChange={e => setName(e.target.value)}
                  className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none focus:border-emerald-500"
                />
              </div>
              <div>
                <label className="block text-4xs text-slate-400 mb-1 font-bold">年齢 <span className="text-rose-500">*</span></label>
                <input 
                  type="number" 
                  required 
                  min="15" 
                  max="80" 
                  placeholder="例：20" 
                  value={age}
                  onChange={e => setAge(e.target.value)}
                  className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none focus:border-emerald-500"
                />
              </div>
              <div>
                <label className="block text-4xs text-slate-400 mb-1 font-bold">学校 / 職業 <span className="text-rose-500">*</span></label>
                <input 
                  type="text" 
                  required 
                  placeholder="例：〇〇大学 2年" 
                  value={job}
                  onChange={e => setJob(e.target.value)}
                  className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none focus:border-emerald-500"
                />
              </div>
            </div>

            <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label className="block text-4xs text-slate-400 mb-1 font-bold">面接日</label>
                <input 
                  type="date" 
                  value={interviewDate}
                  onChange={e => setInterviewDate(e.target.value)}
                  className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none focus:border-emerald-500"
                />
              </div>
              <div>
                <label className="block text-4xs text-slate-400 mb-1 font-bold">電話番号</label>
                <input 
                  type="tel" 
                  placeholder="例：090-0000-0000" 
                  value={phone}
                  onChange={e => setPhone(e.target.value)}
                  className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none focus:border-emerald-500"
                />
              </div>
              <div className="col-span-1 sm:col-span-2">
                <label className="block text-4xs text-slate-400 mb-1 font-bold">現住所</label>
                <input 
                  type="text" 
                  placeholder="例：伊万里市蓮池町◯-◯" 
                  value={address}
                  onChange={e => setAddress(e.target.value)}
                  className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none focus:border-emerald-500"
                />
              </div>
            </div>
          </div>

          {/* セクション2: 勤務条件希望 */}
          <div className="space-y-2.5 border-b border-slate-100 pb-3.5">
            <h4 className="text-4xs font-black text-emerald-600 uppercase tracking-widest flex items-center gap-1">
              <span className="w-1 h-2.5 bg-emerald-500 rounded-full" />
              2. シフト希望・条件
            </h4>
            
            <div className="space-y-2">
              <div>
                <label className="block text-4xs text-slate-400 mb-1.5 font-bold">勤務可能曜日（タップトグル）</label>
                <div className="flex gap-1.5">
                  {["月", "火", "水", "木", "金", "土", "日"].map(day => {
                    const isSel = selectedWeekdays.includes(day);
                    return (
                      <button
                        type="button"
                        key={day}
                        onClick={() => handleWeekdayToggle(day)}
                        className={`flex-1 py-1.5 text-center font-bold border rounded-md transition ${isSel ? 'bg-emerald-500 text-white border-emerald-500' : 'bg-white border-slate-200 text-slate-600 hover:bg-slate-50'}`}
                      >
                        {day}
                      </button>
                    );
                  })}
                </div>
              </div>

              <div className="grid grid-cols-1 sm:grid-cols-3 gap-3 pt-1">
                <div>
                  <label className="block text-4xs text-slate-400 mb-1 font-bold">希望日数</label>
                  <button
                    type="button"
                    onClick={() => setShowingDaysPicker(true)}
                    className="w-full text-left px-3 py-2 bg-slate-50 border border-slate-300 rounded-md text-xs text-emerald-600 font-bold hover:bg-slate-100 transition"
                  >
                    {weeklyDays}
                  </button>
                </div>
                <div>
                  <label className="block text-4xs text-slate-400 mb-1 font-bold">希望時間帯 (平日)</label>
                  <input 
                    type="text" 
                    placeholder="例：17:00〜22:00" 
                    value={hoursWeekday}
                    onChange={e => setHoursWeekday(e.target.value)}
                    className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none focus:border-emerald-500"
                  />
                </div>
                <div>
                  <label className="block text-4xs text-slate-400 mb-1 font-bold">希望時間帯 (土日祝)</label>
                  <input 
                    type="text" 
                    placeholder="例：10:00〜21:00" 
                    value={hoursWeekend}
                    onChange={e => setHoursWeekend(e.target.value)}
                    className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none focus:border-emerald-500"
                  />
                </div>
              </div>

              <div className="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-1">
                <div>
                  <label className="block text-4xs text-slate-400 mb-1 font-bold">通勤方法</label>
                  <select
                    value={commute}
                    onChange={e => setCommute(e.target.value)}
                    className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none cursor-pointer"
                  >
                    {commuteOptions.map(opt => <option key={opt} value={opt}>{opt}</option>)}
                  </select>
                </div>
                <div>
                  <label className="block text-4xs text-slate-400 mb-1 font-bold">希望勤務期間</label>
                  <select
                    value={period}
                    onChange={e => setPeriod(e.target.value)}
                    className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none cursor-pointer"
                  >
                    {periodOptions.map(opt => <option key={opt} value={opt}>{opt}</option>)}
                  </select>
                </div>
              </div>
            </div>
          </div>

          {/* セクション3: 5段階評価入力 */}
          <div className="space-y-2.5 border-b border-slate-100 pb-3.5">
            <h4 className="text-4xs font-black text-emerald-600 uppercase tracking-widest flex items-center gap-1">
              <span className="w-1 h-2.5 bg-emerald-500 rounded-full" />
              3. 面接詳細評価 (1〜5段階)
            </h4>
            
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {evalFields.map(field => {
                const score = evalScores[field.id] ?? 3;
                return (
                  <div key={field.id} className="flex items-center justify-between p-2 border border-slate-100 rounded-lg bg-slate-50/50">
                    <span className="font-bold text-slate-700">{field.name}</span>
                    <div className="flex gap-1">
                      {[1, 2, 3, 4, 5].map(num => (
                        <button
                          type="button"
                          key={num}
                          onClick={() => setEvalScores({ ...evalScores, [field.id]: num })}
                          className={`w-7 h-7 rounded-full text-3xs font-black border transition ${score === num ? 'bg-emerald-500 text-white border-emerald-500 scale-105 shadow-sm' : 'bg-white border-slate-200 text-slate-500 hover:border-slate-300'}`}
                        >
                          {num}
                        </button>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          {/* セクション4: タグ選択 & ステータス */}
          <div className="space-y-2.5 border-b border-slate-100 pb-3.5">
            <h4 className="text-4xs font-black text-emerald-600 uppercase tracking-widest flex items-center gap-1">
              <span className="w-1 h-2.5 bg-emerald-500 rounded-full" />
              4. 属性タグ ＆ ステータス
            </h4>

            <div>
              <label className="block text-4xs text-slate-400 mb-1.5 font-bold">属性タグ（複数選択可）</label>
              <div className="flex flex-wrap gap-1.5">
                {allTags.map(tag => {
                  const isSel = selectedTags.includes(tag);
                  return (
                    <button
                      type="button"
                      key={tag}
                      onClick={() => handleTagToggle(tag)}
                      className={`px-3 py-1 border rounded-md font-bold text-3xs transition ${isSel ? 'bg-emerald-50 text-emerald-600 border-emerald-300' : 'bg-white text-slate-500 border-slate-200 hover:bg-slate-50'}`}
                    >
                      # {tag}
                    </button>
                  );
                })}
              </div>
            </div>

            <div className="pt-1">
              <label className="block text-4xs text-slate-400 mb-1.5 font-bold">採用状況選考ステータス</label>
              <div className="grid grid-cols-5 gap-1.5">
                {statusOptions.map(opt => {
                  const isSel = status === opt;
                  return (
                    <button
                      type="button"
                      key={opt}
                      onClick={() => setStatus(opt)}
                      className={`py-2 text-3xs font-black rounded-lg border text-center transition ${isSel ? 'bg-emerald-500 text-white border-emerald-500' : 'bg-white border-slate-200 text-slate-500 hover:bg-slate-50'}`}
                    >
                      {opt}
                    </button>
                  );
                })}
              </div>
            </div>
          </div>

          {/* セクション5: メモ特記事項 */}
          <div className="space-y-2.5">
            <h4 className="text-4xs font-black text-emerald-600 uppercase tracking-widest flex items-center gap-1">
              <span className="w-1 h-2.5 bg-emerald-500 rounded-full" />
              5. 特記事項・自由記入
            </h4>
            <textarea 
              rows={3}
              placeholder="「笑顔がよく、元気に挨拶ができていた」「主婦仲間とのコミュニティあり」「ランチピーク帯週4日固定可能」など店長の見解をメモ..."
              value={notes}
              onChange={e => setNotes(e.target.value)}
              className="w-full p-2.5 border border-slate-300 rounded-lg text-xs text-slate-800 bg-white focus:outline-none focus:border-emerald-500 placeholder-slate-400"
            />
          </div>

          {/* フッター */}
          <div className="pt-2 flex justify-end gap-2 border-t border-slate-100 shrink-0">
            <button 
              type="button" 
              onClick={onClose}
              className="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg font-bold"
            >
              キャンセル
            </button>
            <button 
              type="submit"
              className="px-5 py-2 bg-emerald-500 hover:bg-emerald-600 text-white rounded-lg font-bold shadow-sm shadow-emerald-500/10"
            >
              保存する
            </button>
          </div>
        </form>
      </div>

      {/* 希望日数セレクトモーダル（ポップアップ重なり） */}
      {showingDaysPicker && (
        <div className="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
          <div className="bg-white rounded-xl shadow-2xl max-w-xs w-full overflow-hidden animate-in zoom-in duration-100 border border-slate-200">
            <div className="p-3 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
              <span className="font-extrabold text-slate-800 text-xs">希望日数の選択</span>
              <button 
                type="button" 
                onClick={() => setShowingDaysPicker(false)}
                className="text-slate-400 hover:text-slate-600"
              >
                <X className="w-4 h-4" />
              </button>
            </div>
            <div className="max-h-60 overflow-y-auto divide-y divide-slate-100 text-xs">
              {daysOptions.map(opt => (
                <button
                  type="button"
                  key={opt}
                  onClick={() => {
                    setWeeklyDays(opt);
                    showingDaysPicker ? setShowingDaysPicker(false) : null;
                  }}
                  className="w-full px-4 py-2.5 text-left hover:bg-slate-50 flex justify-between items-center"
                >
                  <span className={weeklyDays === opt ? "font-bold text-emerald-600" : "text-slate-700"}>
                    {opt}
                  </span>
                  {weeklyDays === opt && <Check className="w-3.5 h-3.5 text-emerald-500" />}
                </button>
              ))}
            </div>
          </div>
        </div>
      )}

    </div>
  );
}

// ────────────────────────────────────────────────────────
// MARK: - 項目設定・管理用モーダル
// ────────────────────────────────────────────────────────
interface SettingsModalProps {
  evalFields: EvalField[];
  onClose: () => void;
  onSaveFields: (updated: EvalField[]) => void;
  triggerToast: (msg: string) => void;
}

function SettingsModalComponent({
  evalFields,
  onClose,
  onSaveFields,
  triggerToast
}: SettingsModalProps) {

  const [newFieldName, setNewFieldName] = useState('');
  const [selectedIcon, setSelectedIcon] = useState('star');
  const [fieldsList, setFieldsList] = useState<EvalField[]>([]);

  // 削除用の状態（設定画面の上にシームレスに重なる）
  const [showingFieldDeleteConfirm, setShowingFieldDeleteConfirm] = useState<boolean>(false);
  const [fieldToDelete, setFieldToDelete] = useState<EvalField | null>(null);

  useEffect(() => {
    setFieldsList(evalFields);
  }, [evalFields]);

  const iconOptions = [
    'star', 'smile', 'message-square', 'sparkles', 'shield-check', 'zap', 'briefcase', 'clock', 'calendar'
  ];

  const handleAddField = () => {
    const trimmed = newFieldName.trim();
    if (!trimmed) return;

    const newField: EvalField = {
      id: `custom-${Date.now()}`,
      name: trimmed,
      icon: selectedIcon
    };

    const updated = [...fieldsList, newField];
    setFieldsList(updated);
    onSaveFields(updated);
    setNewFieldName('');
  };

  const handleDeleteFieldClick = (field: EvalField) => {
    if (fieldsList.count <= 3) {
      triggerToast("評価項目は最低3つ以上必要です");
      return;
    }
    setFieldToDelete(field);
    setShowingFieldDeleteConfirm(true);
  };

  const confirmDeleteField = () => {
    if (!fieldToDelete) return;
    const updated = fieldsList.filter(f => f.id !== fieldToDelete.id);
    setFieldsList(updated);
    onSaveFields(updated);
    setShowingFieldDeleteConfirm(false);
    setFieldToDelete(null);
    triggerToast(`「${fieldToDelete.name}」項目を削除しました`);
  };

  return (
    <div className="fixed inset-0 bg-black/60 backdrop-blur-xs z-40 flex items-center justify-center p-3 sm:p-5 overflow-y-auto">
      
      {/* 項目設定ダイアログ本体 */}
      <div className="bg-white rounded-xl border border-slate-200 shadow-2xl w-full max-w-md max-h-[90vh] flex flex-col overflow-hidden animate-in fade-in zoom-in duration-150 relative">
        
        {/* ヘッダー */}
        <div className="px-5 py-3.5 bg-slate-50 border-b border-slate-200 flex justify-between items-center shrink-0">
          <h3 className="text-sm font-extrabold text-slate-800 flex items-center gap-1.5">
            <Settings className="w-4.5 h-4.5 text-slate-500" />
            <span>面接評価項目の設定</span>
          </h3>
          <button 
            onClick={onClose}
            className="w-7 h-7 rounded-full bg-slate-100 hover:bg-slate-200 text-slate-500 flex items-center justify-center transition"
          >
            <X className="w-4 h-4" />
          </button>
        </div>

        {/* コンテンツリスト */}
        <div className="flex-1 overflow-y-auto p-5 space-y-4 text-xs">
          
          {/* 現在の項目リスト */}
          <div className="space-y-2">
            <span className="block text-4xs font-bold text-slate-400 uppercase tracking-wider">
              登録済みの項目 (最低3つ必須)
            </span>
            <div className="space-y-1.5 max-h-52 overflow-y-auto pr-1">
              {fieldsList.map(field => {
                const IconComponent = iconMap[field.icon] || Star;
                return (
                  <div key={field.id} className="flex items-center justify-between p-2 border border-slate-150 rounded-lg bg-slate-50">
                    <span className="flex items-center gap-2 font-bold text-slate-700">
                      <IconComponent className="w-4 h-4 text-emerald-500" />
                      {field.name}
                    </span>
                    <button
                      type="button"
                      title="本当に削除しますか？"
                      onClick={() => handleDeleteFieldClick(field)}
                      className="p-1 text-rose-500 hover:bg-rose-50 rounded border border-rose-200 transition"
                    >
                      <Trash2 className="w-3.5 h-3.5" />
                    </button>
                  </div>
                );
              })}
            </div>
          </div>

          {/* 新規追加セクション */}
          <div className="border-t border-slate-100 pt-3.5 space-y-3">
            <span className="block text-4xs font-bold text-slate-400 uppercase tracking-wider">
              新しい項目を追加
            </span>
            
            <div className="space-y-2">
              <input 
                type="text" 
                placeholder="例：接客経験の有無" 
                value={newFieldName}
                onChange={e => setNewFieldName(e.target.value)}
                className="w-full px-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-800 focus:outline-none focus:border-emerald-500"
              />

              {/* アイコンセレクタ */}
              <div className="space-y-1">
                <span className="block text-4xs text-slate-400 font-bold">表現アイコンの選択</span>
                <div className="grid grid-cols-5 gap-1.5 pt-1">
                  {iconOptions.map(icon => {
                    const IconComp = iconMap[icon];
                    return (
                      <button
                        type="button"
                        key={icon}
                        onClick={() => setSelectedIcon(icon)}
                        className={`py-2 flex items-center justify-center rounded-lg border transition ${selectedIcon === icon ? 'bg-emerald-500 border-emerald-500 text-white' : 'bg-white border-slate-200 text-slate-500 hover:bg-slate-50'}`}
                      >
                        {IconComp && <IconComp className="w-4 h-4" />}
                      </button>
                    );
                  })}
                </div>
              </div>

              <button
                type="button"
                onClick={handleAddField}
                disabled={!newFieldName.trim()}
                className={`w-full py-2 rounded-lg font-bold text-xs text-white transition ${newFieldName.trim() ? 'bg-emerald-500 hover:bg-emerald-600 shadow-sm' : 'bg-slate-300 cursor-not-allowed'}`}
              >
                新しい項目を追加
              </button>
            </div>
          </div>

        </div>

        {/* 完了ボタン */}
        <div className="p-4 bg-slate-50 border-t border-slate-150 flex justify-end shrink-0">
          <button 
            onClick={onClose}
            className="px-5 py-1.5 bg-slate-200 hover:bg-slate-300 text-slate-700 rounded-lg font-bold text-xs transition"
          >
            設定完了
          </button>
        </div>

        {/* ⚙️設定モーダルの真上にシームレスに重なるカスタム確認ダイアログ */}
        {showingFieldDeleteConfirm && fieldToDelete && (
          <div className="absolute inset-0 bg-black/55 z-[70] flex items-center justify-center p-4">
            <div className="bg-white rounded-xl border border-slate-200 shadow-2xl max-w-[270px] w-full overflow-hidden animate-in zoom-in duration-150">
              <div className="p-4 text-center space-y-2">
                <div className="w-10 h-10 bg-rose-50 text-rose-500 rounded-full flex items-center justify-center mx-auto border border-rose-200">
                  <AlertTriangle className="w-5 h-5" />
                </div>
                <h4 className="text-xs font-bold text-slate-900">本当に削除しますか？</h4>
                <p className="text-4xs text-slate-500 leading-relaxed">
                  項目「{fieldToDelete.name}」を削除しますか？<br />過去データでもこの項目は非表示になります。
                </p>
              </div>
              <div className="border-t border-slate-100 flex divide-x divide-slate-100 text-xs">
                <button 
                  onClick={() => setShowingFieldDeleteConfirm(false)}
                  className="flex-1 py-2.5 text-center text-slate-600 font-bold hover:bg-slate-50"
                >
                  キャンセル
                </button>
                <button 
                  onClick={confirmDeleteField}
                  className="flex-1 py-2.5 text-center text-rose-600 font-bold hover:bg-rose-50"
                >
                  削除する
                </button>
              </div>
            </div>
          </div>
        )}

      </div>
    </div>
  );
}

