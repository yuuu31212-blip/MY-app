function getStatusColorClass(status: string) {
  switch (status) {
    case '面接予定': return 'bg-blue-500';
    case '検討中': return 'bg-orange-400';
    case '採用': return 'bg-emerald-500';
    case '不採用': return 'bg-rose-500';
    default: return 'bg-slate-400';
  }
}

function getStatusBadgeClass(status: string) {
  switch (status) {
    case '面接予定': return 'bg-blue-50 text-blue-600 border-blue-200';
    case '検討中': return 'bg-orange-50 text-orange-600 border-orange-200';
    case '採用': return 'bg-emerald-50 text-emerald-600 border-emerald-200';
    case '不採用': return 'bg-rose-50 text-rose-600 border-rose-200';
    default: return 'bg-slate-100 text-slate-600 border-slate-300';
  }
}s