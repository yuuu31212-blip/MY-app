import React, { useState, useEffect, useMemo, useRef } from 'react';
import { 
  Plus, 
  Settings, 
  Trash2, 
  Edit, 
  Search, 
  FileText, 
  Check, 
  AlertTriangle, 
  Calendar, 
  MapPin, 
  Phone, 
  Clock, 
  ArrowLeft, 
  Download, 
  Upload, 
  Star, 
  ChevronDown, 
  UserPlus, 
  X,
  Sparkles,
  Smile,
  MessageSquare,
  ShieldCheck,
  Zap,
  Briefcase
} from 'lucide-react';

// MARK: - Models & Types

interface Candidate {
  id: string;
  name: string;
  age: number;
  job: string;
  phone: string;
  address: string; // 住所
  weekdays: string[];
  weeklyDays: string;
  hoursWeekday: string;
  hoursWeekend: string;
  commute: string;
  period: string;
  eval: { [key: string]: number }; // 評価項目ID -> スコア (1~5)
  tags: string[];
  status: string;
  createdAt: number;
}

interface EvalField {
  id: string;
  name: string;
  icon: string; // lucideアイコン識別名
}

// 評価用アイコンマッピング
const iconMap: { [key: string]: React.ComponentType<any> } = {
  'smile': Smile,
  'message-square': MessageSquare,
  'sparkles': Sparkles,
  'shield-check': ShieldCheck,
  'zap': Zap,
  'briefcase': Briefcase,
  'star': Star,
  'clock': Clock,
  'calendar': Calendar,
};

export default function App() {
  // --- アプリケーション状態 ---
  const [candidates, setCandidates] = useState<Candidate[]>([]);
  const [evalFields, setEvalFields] = useState<EvalField[]>([]);
  const [selectedCandidateId, setSelectedCandidateId] = useState<string | null>(null);
  const [activeFilterStatus, setActiveFilterStatus] = useState<string>('all');
  const [activeFilterTags, setActiveFilterTags] = useState<string[]>([]);
  const [searchText, setSearchText] = useState<string>('');
  const [sortOption, setSortOption] = useState<string>('newest');

  // モーダル・ダイアログ管理
  const [showingAddEditModal, setShowingAddEditModal] = useState<boolean>(false);
  const [editingCandidate, setEditingCandidate] = useState<Candidate | null>(null);
  const [showingSettingsModal, setShowingSettingsModal] = useState<boolean>(false);
  
  // カスタム確認アラート
  const [showingDeleteConfirm, setShowingDeleteConfirm] = useState<boolean>(false);
  const [candidateToDelete, setCandidateToDelete] = useState<Candidate | null>(null);
  
  // トースト通知
  const [toastMessage, setToastMessage] = useState<string | null>(null);
  const [showToast, setShowToast] = useState<boolean>(false);

  // モバイル画面でのビュー切り替え（モバイル時には詳細画面を重ねる）
  const [isMobileDetailActive, setIsMobileDetailActive] = useState<boolean>(false);

  // --- マスター設定データ ---
  const allTags = [
    "高校生", "大学生", "主婦", "フリーター",
    "長期希望", "土日可能", "夜勤務可能",
    "即採用候補", "教育必要", "不安あり"
  ];

  const statusOptions = ["面接予定", "検討中", "採用", "不採用", "辞退"];
  const commuteOptions = ["徒歩", "自転車", "原付・バイク", "電車・バス", "車通勤"];
  const periodOptions = ["長期可能 (1年以上)", "半年以上", "3ヶ月以上", "短期 (3ヶ月未満)"];

  // --- データの初期読み込み (localStorage) ---
  useEffect(() => {
    // 評価項目の初期化
    const storedFields = localStorage.getItem('Mennsetu_eval_fields');
    let fields: EvalField[] = [];
    if (storedFields) {
      try {
        fields = JSON.parse(storedFields);
      } catch (e) {
        console.error(e);
      }
    }
    
    if (fields.length === 0) {
      fields = [
        { id: "aiso", name: "愛想・笑顔", icon: "smile" },
        { id: "seiryo", name: "声量・ハキハキ", icon: "message-square" },
        { id: "seiketsu", name: "身だしなみ・清潔感", icon: "sparkles" },
        { id: "comm", name: "コミュ力", icon: "shield-check" },
        { id: "majime", name: "真面目さ", icon: "star" },
        { id: "antei", name: "シフト安定性", icon: "clock" },
        { id: "sokusen", name: "即戦力期待", icon: "zap" }
      ];
      localStorage.setItem('Mennsetu_eval_fields', JSON.stringify(fields));
    }
    setEvalFields(fields);

    // 候補者データの初期化（初期デモデータはなし）
    const storedCandidates = localStorage.getItem('Mennsetu_candidates');
    if (storedCandidates) {
      try {
        const parsed = JSON.parse(storedCandidates);
        setCandidates(parsed);
        if (parsed.length > 0) {
          setSelectedCandidateId(parsed[0].id);
        }
      } catch (e) {
        console.error(e);
      }
    }
  }, []);

  // データが変更されるたびに自動保存
  const saveCandidatesToStorage = (updatedList: Candidate[]) => {
    setCandidates(updatedList);
    localStorage.setItem('Mennsetu_candidates', JSON.stringify(updatedList));
  };

  const saveFieldsToStorage = (updatedFields: EvalField[]) => {
    setEvalFields(updatedFields);
    localStorage.setItem('Mennsetu_eval_fields', JSON.stringify(updatedFields));
  };

  // --- ユーティリティ & ヘルパー ---
  const triggerToast = (msg: string) => {
    setToastMessage(msg);
    setShowToast(true);
    setTimeout(() => {
      setShowToast(false);
    }, 2500);
  };

  // 1人の平均点を計算
  const calculateAverage = (candidate: Candidate) => {
    if (evalFields.length === 0) return 0;
    let sum = 0;
    let count = 0;
    evalFields.forEach(field => {
      const score = candidate.eval[field.id];
      if (score !== undefined) {
        sum += score;
        count++;
      }
    });
    return count > 0 ? sum / count : 0;
  };

  // 統計情報
  const stats = useMemo(() => {
    const total = candidates.length;
    const hired = candidates.filter(c => c.status === '採用').length;
    const rate = total > 0 ? Math.round((hired / total) * 100) : 0;
    
    let totalScoreSum = 0;
    let evalCount = 0;
    candidates.forEach(c => {
      const avg = calculateAverage(c);
      if (avg > 0) {
        totalScoreSum += avg;
        evalCount++;
      }
    });
    const avgScore = evalCount > 0 ? (totalScoreSum / evalCount).toFixed(1) : "0.0";

    return { total, hired, rate, avgScore };
  }, [candidates, evalFields]);

  // 絞り込み ＆ ソート処理
  const filteredCandidates = useMemo(() => {
    let result = [...candidates];

    // ステータスフィルタ
    if (activeFilterStatus !== 'all') {
      result = result.filter(c => c.status === activeFilterStatus);
    }

    // タグフィルタ
    if (activeFilterTags.length > 0) {
      result = result.filter(c => 
        activeFilterTags.every(tag => c.tags.includes(tag))
      );
    }

    // キーワード検索
    if (searchText.trim()) {
      const query = searchText.toLowerCase().trim();
      result = result.filter(c => 
        c.name.toLowerCase().includes(query) ||
        c.job.toLowerCase().includes(query) ||
        c.address.toLowerCase().includes(query) ||
        c.notes.toLowerCase().includes(query)
      );
    }

    // ソート順
    result.sort((a, b) => {
      if (sortOption === 'newest') {
        return b.createdAt - a.createdAt;
      } else if (sortOption === 'eval-desc') {
        return calculateAverage(b) - calculateAverage(a);
      } else if (sortOption === 'eval-asc') {
        return calculateAverage(a) - calculateAverage(b);
      } else if (sortOption === 'name') {
        return a.name.localeCompare(b.name, 'ja');
      }
      return 0;
    });

    return result;
  }, [candidates, activeFilterStatus, activeFilterTags, searchText, sortOption, evalFields]);

  // 選択中の候補者
  const selectedCandidate = useMemo(() => {
    return candidates.find(c => c.id === selectedCandidateId) || null;
  }, [candidates, selectedCandidateId]);

  // 一覧のカードをタップした際のイベント
  const handleSelectCandidate = (id: string) => {
    setSelectedCandidateId(id);
    setIsMobileDetailActive(true); // モバイル時に詳細ビューに切り替え
  };

  // 削除処理
  const handleDeleteClick = (candidate: Candidate) => {
    setCandidateToDelete(candidate);
    showingDeleteConfirm ? null : setShowingDeleteConfirm(true);
  };

  const confirmDeleteCandidate = () => {
    if (!candidateToDelete) return;
    const updated = candidates.filter(c => c.id !== candidateToDelete.id);
    saveCandidatesToStorage(updated);
    
    if (selectedCandidateId === candidateToDelete.id) {
      setSelectedCandidateId(updated.length > 0 ? updated[0].id : null);
    }
    
    setShowingDeleteConfirm(false);
    setCandidateToDelete(null);
    setIsMobileDetailActive(false);
    triggerToast("候補者データを完全に削除しました");
  };

  // インポート・エクスポート
  const exportData = () => {
    const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(candidates, null, 2));
    const downloadAnchor = document.createElement('a');
    downloadAnchor.setAttribute("href", dataStr);
    downloadAnchor.setAttribute("download", `面接スプレッドシート_${new Date().toISOString().split('T')[0]}.json`);
    document.body.appendChild(downloadAnchor);
    downloadAnchor.click();
    downloadAnchor.remove();
    triggerToast("JSON形式でデータをエクスポートしました");
  };

  const handleImport = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (event) => {
      try {
        const parsed = JSON.parse(event.target?.result as string);
        if (Array.isArray(parsed)) {
          saveCandidatesToStorage(parsed);
          if (parsed.length > 0) {
            setSelectedCandidateId(parsed[0].id);
          }
          triggerToast("データのインポートに成功しました");
        } else {
          alert("データ形式が正しくありません。配列データである必要があります。");
        }
      } catch (err) {
        alert("JSONファイルの解析に失敗しました。");
      }
    };
    reader.readAsText(file);
  };

  // PDF印刷出力の呼び出し
  const triggerPrint = () => {
    window.print();
  };

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 flex flex-col font-sans select-none antialiased">
      
      {/* 通常アプリの画面レイアウト (印刷時は隠す) */}
      <div className="flex-1 flex flex-col overflow-hidden print:hidden">
        
        {/* ヘッダー */}
        <header className="bg-white border-b border-slate-200 px-4 py-3 flex items-center justify-between shrink-0 shadow-sm z-10">
          <div className="flex items-center space-x-3">
            <div className="bg-emerald-500 text-white p-2 rounded-lg shadow-sm">
              <FileText className="w-5 h-5" />
            </div>
            <div>
              <h1 className="text-base font-bold tracking-wide text-slate-900 flex items-center gap-1.5">
                面接スプレッドシート
                <span className="text-3xs bg-emerald-50 text-emerald-600 border border-emerald-200 font-bold px-1.5 py-0.5 rounded">
                  OFFLINE
                </span>
              </h1>
              <p className="text-4xs text-slate-400">飲食店舗向け面接評価・シフト管理</p>
            </div>
          </div>
          
          <div className="flex items-center space-x-1.5">
            <button 
              onClick={exportData}
              title="データをJSONでバックアップ"
              className="p-1.5 sm:px-3 sm:py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-md text-xs font-semibold transition flex items-center gap-1.5 border border-slate-200"
            >
              <Download className="w-3.5 h-3.5" />
              <span className="hidden sm:inline">エクスポート</span>
            </button>
            <label className="p-1.5 sm:px-3 sm:py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-md text-xs font-semibold transition flex items-center gap-1.5 border border-slate-200 cursor-pointer">
              <Upload className="w-3.5 h-3.5" />
              <span className="hidden sm:inline">インポート</span>
              <input type="file" accept=".json" onChange={handleImport} className="hidden" />
            </label>
            <button 
              onClick={() => {
                setShowingSettingsModal(true);
              }}
              className="p-1.5 sm:px-3 sm:py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-md text-xs font-semibold transition flex items-center gap-1.5 border border-slate-200"
            >
              <Settings className="w-3.5 h-3.5" />
              <span className="hidden sm:inline">項目設定</span>
            </button>
            <button 
              onClick={() => {
                setEditingCandidate(null);
                setShowingAddEditModal(true);
              }}
              className="p-1.5 sm:px-4 sm:py-1.5 bg-emerald-500 hover:bg-emerald-600 text-white rounded-md text-xs font-bold transition flex items-center gap-1.5 shadow-sm shadow-emerald-500/10"
            >
              <Plus className="w-4 h-4" />
              <span>新規登録</span>
            </button>
          </div>
        </header>

        {/* 統計情報ダッシュボード */}
        <div className="bg-slate-100 border-b border-slate-200 px-4 py-2.5 shrink-0 grid grid-cols-4 gap-2">
          <div className="bg-white p-2.5 rounded-lg border border-slate-200 flex items-center justify-between">
            <div>
              <p className="text-4xs text-slate-400 font-bold uppercase">総面接人数</p>
              <p className="text-sm sm:text-base font-black text-slate-800 mt-0.5">{stats.total}人</p>
            </div>
            <div className="w-7 h-7 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center">
              <UserPlus className="w-4 h-4" />
            </div>
          </div>
          
          <div className="bg-white p-2.5 rounded-lg border border-slate-200 flex items-center justify-between">
            <div>
              <p className="text-4xs text-slate-400 font-bold uppercase">採用者数</p>
              <p className="text-sm sm:text-base font-black text-emerald-600 mt-0.5">{stats.hired}人</p>
            </div>
            <div className="w-7 h-7 bg-emerald-50 text-emerald-500 rounded-full flex items-center justify-center">
              <Check className="w-4 h-4" />
            </div>
          </div>

          <div className="bg-white p-2.5 rounded-lg border border-slate-200 flex items-center justify-between">
            <div>
              <p className="text-4xs text-slate-400 font-bold uppercase">採用率</p>
              <p className="text-sm sm:text-base font-black text-amber-500 mt-0.5">{stats.rate}%</p>
            </div>
            <div className="w-7 h-7 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center">
              <Star className="w-4 h-4" />
            </div>
          </div>

          <div className="bg-white p-2.5 rounded-lg border border-slate-200 flex items-center justify-between">
            <div>
              <p className="text-4xs text-slate-400 font-bold uppercase">候補者全体平均</p>
              <p className="text-sm sm:text-base font-black text-purple-600 mt-0.5">{stats.avgScore}</p>
            </div>
            <div className="w-7 h-7 bg-purple-50 text-purple-500 rounded-full flex items-center justify-center">
              <Star className="w-4 h-4 fill-purple-500" />
            </div>
          </div>
        </div>

        {/* メイングリッドエリア */}
        <div className="flex-1 flex overflow-hidden relative">
          
          {/* 左側: 候補者一覧 */}
          <div className="w-full md:w-[45%] lg:w-[40%] flex flex-col border-r border-slate-200 bg-white h-full overflow-hidden">
            
            {/* 検索・クイックフィルタ */}
            <div className="p-3 bg-slate-50 border-b border-slate-200 flex flex-col gap-2 shrink-0">
              <div className="flex gap-1.5">
                <div className="relative flex-1">
                  <Search className="w-3.5 h-3.5 text-slate-400 absolute left-2.5 top-2.5" />
                  <input 
                    type="text" 
                    placeholder="名前、学校、住所、メモを検索..." 
                    value={searchText}
                    onChange={(e) => setSearchText(e.target.value)}
                    className="w-full pl-8 pr-3 py-1.5 bg-white border border-slate-300 rounded-md text-xs placeholder-slate-400 focus:outline-none focus:border-emerald-500 transition-colors"
                  />
                </div>
                
                <div className="relative">
                  <select 
                    value={sortOption}
                    onChange={(e) => setSortOption(e.target.value)}
                    className="pl-2 pr-7 py-1.5 bg-white border border-slate-300 rounded-md text-xs text-slate-700 font-semibold focus:outline-none appearance-none cursor-pointer"
                  >
                    <option value="newest">🆕 新着順</option>
                    <option value="eval-desc">⭐ 評価高順</option>
                    <option value="eval-asc">⚠️ 評価低順</option>
                    <option value="name">🔤 名前順</option>
                  </select>
                  <ChevronDown className="w-3 h-3 text-slate-500 absolute right-2.5 top-2.5 pointer-events-none" />
                </div>
              </div>

              {/* ステータスフィルタタブ */}
              <div className="flex gap-1 overflow-x-auto pb-1 scrollbar-none text-2xs">
                <button 
                  onClick={() => setActiveFilterStatus('all')}
                  className={`px-3 py-1 font-bold rounded-full shrink-0 transition ${activeFilterStatus === 'all' ? 'bg-emerald-500 text-white' : 'bg-slate-200/60 text-slate-600 hover:bg-slate-200'}`}
                >
                  全て ({candidates.length})
                </button>
                {statusOptions.map(status => {
                  const count = candidates.filter(c => c.status === status).length;
                  return (
                    <button 
                      key={status}
                      onClick={() => setActiveFilterStatus(status)}
                      className={`px-3 py-1 font-bold rounded-full shrink-0 transition ${activeFilterStatus === status ? 'bg-emerald-500 text-white' : 'bg-slate-200/60 text-slate-600 hover:bg-slate-200'}`}
                    >
                      {status} ({count})
                    </button>
                  );
                })}
              </div>

              {/* タグクイック選択 */}
              <div className="flex gap-1 overflow-x-auto pb-1 scrollbar-none text-3xs border-t border-slate-200/50 pt-2">
                {allTags.map(tag => {
                  const isActive = activeFilterTags.includes(tag);
                  return (
                    <button
                      key={tag}
                      onClick={() => {
                        if (isActive) {
                          setActiveFilterTags(activeFilterTags.filter(t => t !== tag));
                        } else {
                          setActiveFilterTags([...activeFilterTags, tag]);
                        }
                      }}
                      className={`px-2.5 py-1 rounded-full shrink-0 font-bold transition ${isActive ? 'bg-emerald-50 text-emerald-600 border border-emerald-300' : 'bg-white text-slate-500 border border-slate-200 hover:bg-slate-100'}`}
                    >
                      # {tag}
                    </button>
                  );
                })}
              </div>
            </div>

            {/* 候補者リスト */}
            <div className="flex-1 overflow-y-auto p-3 space-y-2 bg-slate-50">
              {filteredCandidates.length === 0 ? (
                <div className="py-12 text-center text-slate-400">
                  <FileText className="w-8 h-8 mx-auto mb-2 text-slate-300" />
                  <p className="text-xs">条件に合致する候補者はいません</p>
                </div>
              ) : (
                filteredCandidates.map(c => {
                  const avg = calculateAverage(c);
                  const isSelected = c.id === selectedCandidateId;
                  return (
                    <div
                      key={c.id}
                      onClick={() => handleSelectCandidate(c.id)}
                      className={`p-3 bg-white border rounded-xl cursor-pointer transition-all duration-150 relative overflow-hidden ${isSelected ? 'border-emerald-500 ring-2 ring-emerald-500/10 scale-[1.01]' : 'border-slate-200 hover:border-slate-300'}`}
                    >
                      {/* 左端ステータスカラー */}
                      <div className={`absolute left-0 top-0 bottom-0 w-1 ${getStatusColorClass(c.status)}`} />
                      
                      <div className="pl-1.5 space-y-1.5">
                        <div className="flex justify-between items-start">
                          <div>
                            <span className="text-xs font-black text-slate-800">{c.name}</span>
                            <span className="text-4xs text-slate-400 ml-1.5">{c.age}歳 ｜ {c.job}</span>
                          </div>
                          <span className={`text-4xs font-bold px-1.5 py-0.5 rounded ${getStatusBadgeClass(c.status)}`}>
                            {c.status}
                          </span>
                        </div>

                        <div className="flex justify-between items-center text-3xs">
                          <span className="flex items-center gap-1 font-bold text-slate-700">
                            <Star className="w-3 h-3 text-amber-500 fill-amber-500" />
                            {avg.toFixed(1)}
                          </span>
                          
                          {c.weekdays.length > 0 && (
                            <span className="px-1.5 py-0.5 bg-emerald-50 text-emerald-600 font-bold rounded">
                              {c.weekdays.join(', ')}
                            </span>
                          )}
                        </div>

                        {c.notes && (
                          <p className="text-4xs text-slate-500 truncate italic bg-slate-50 px-1.5 py-1 rounded">
                            "{c.notes}"
                          </p>
                        )}

                        <div className="flex flex-wrap gap-1">
                          {c.tags.map(tag => (
                            <span key={tag} className="text-4xs font-semibold px-1 py-0.2 bg-slate-100 text-slate-500 rounded">
                              #{tag}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>
                  );
                })
              )}
            </div>
          </div>

          {/* 右側: 候補者詳細（デスクトップ・iPadでは表示、モバイルではスライドイン） */}
          <div className={`absolute inset-0 md:relative md:flex flex-col flex-1 bg-white z-20 transition-transform duration-200 ease-out ${isMobileDetailActive ? 'translate-x-0' : 'translate-x-full md:translate-x-0'}`}>
            {selectedCandidate ? (
              <div className="h-full flex flex-col overflow-hidden bg-slate-100">
                {/* 詳細ヘッダー */}
                <div className="bg-white border-b border-slate-200 px-4 py-2.5 flex items-center justify-between shrink-0">
                  <div className="flex items-center gap-2">
                    <button 
                      onClick={() => setIsMobileDetailActive(false)}
                      className="md:hidden p-1 bg-slate-100 rounded-full text-slate-600 hover:bg-slate-200"
                    >
                      <ArrowLeft className="w-4 h-4" />
                    </button>
                    <span className="text-xs font-bold text-slate-400">詳細カルテ</span>
                  </div>
                  
                  <div className="flex items-center space-x-1.5">
                    <button 
                      onClick={triggerPrint}
                      className="px-3 py-1.5 bg-blue-500 hover:bg-blue-600 text-white rounded-md text-xs font-bold transition flex items-center gap-1"
                    >
                      <FileText className="w-3.5 h-3.5" />
                      <span>PDF印刷</span>
                    </button>
                    <button 
                      onClick={() => {
                        setEditingCandidate(selectedCandidate);
                        setShowingAddEditModal(true);
                      }}
